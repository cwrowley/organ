<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.clancy.organ</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/clancy/organ/backend/.venv/bin/uvicorn</string>
        <string>organ.main:app</string>
        <string>--host</string>
        <string>0.0.0.0</string>
        <string>--port</string>
        <string>1685</string>
        <string>--ssl-certfile</string>
        <string>/etc/tailscale/certs/organ.crt</string>
        <string>--ssl-keyfile</string>
        <string>/etc/tailscale/certs/organ.key</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/clancy/organ/backend</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/clancy/logs/organ.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/clancy/logs/organ.err</string>
</dict>
</plist>
